# CalcVerse Environment Variables

# Copy this file to .env.local and fill in your values
# Variable names starting with NEXT_PUBLIC_ are exposed to the browser

# Google Analytics (optional but recommended for tracking)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# API Endpoints (optional, for future API integration)
# NEXT_PUBLIC_API_URL=https://api.calcverse.in
# API_SECRET_KEY=your_secret_key_here

# Database (optional, for user preferences/saved calculations)
# DATABASE_URL=postgresql://user:password@localhost:5432/calcverse

# Authentication (optional, for future login feature)
# NEXTAUTH_SECRET=generated_secret_key
# NEXTAUTH_URL=https://calcverse.in

# Email Service (optional, for contact form)
# SENDGRID_API_KEY=your_sendgrid_key
# CONTACT_EMAIL=admin@calcverse.in

# Environment
NODE_ENV=development
